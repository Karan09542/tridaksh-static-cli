{
  "name": "@tridaksh/static-cli",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "private": true,
  "bin": {
    "static": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc && npm run copyfiles",
    "dev": "tsc -w && npm run copyfiles",
    "copyfiles": "copyfiles -u 1 src/public/**/* dist && copyfiles -u 1 src/gui/**/* dist"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "tridaksh",
    "tridaksh static server",
    "tradaksh-static-server",
    "static",
    "static cli",
    "static cli tool",
    "static server cli",
    "static file server"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "busboy": "^1.6.0",
    "chalk": "^5.6.2",
    "mime-types": "^3.0.2",
    "minimatch": "^10.2.4"
  },
  "homepage": "https://static-cli.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Karan09542/tridaksh-static-cli.git"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/busboy": "^1.5.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.2.3",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.11",
    "typescript": "^5.9.3"
  }
}
